{
  "title": "DevOps Final – Container Overview",
  "uid": "devops-final-containers",
  "schemaVersion": 36,
  "version": 2,
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage per Container (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{image!='', container!='POD'}[1m]) * 100",
          "legendFormat": "{{ name }}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "title": "Memory Usage per Container",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{image!='', container!='POD'}",
          "legendFormat": "{{ name }}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 3,
      "title": "Container Status",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "clamp_max(count(container_start_time_seconds{name=\"devops-final-alertmanager-1\"}), 1) or on() vector(0)",
          "legendFormat": "alertmanager",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "clamp_max(count(container_start_time_seconds{name=\"devops-final-app-1\"}), 1) or on() vector(0)",
          "legendFormat": "app-1",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "clamp_max(count(container_start_time_seconds{name=\"devops-final-app-2\"}), 1) or on() vector(0)",
          "legendFormat": "app-2",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "clamp_max(count(container_start_time_seconds{name=\"devops-final-cadvisor-1\"}), 1) or on() vector(0)",
          "legendFormat": "cadvisor",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "clamp_max(count(container_start_time_seconds{name=\"devops-final-certbot-1\"}), 1) or on() vector(0)",
          "legendFormat": "certbot",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "clamp_max(count(container_start_time_seconds{name=\"devops-final-db-1\"}), 1) or on() vector(0)",
          "legendFormat": "db",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "clamp_max(count(container_start_time_seconds{name=\"devops-final-grafana\"}), 1) or on() vector(0)",
          "legendFormat": "grafana",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "clamp_max(count(container_start_time_seconds{name=\"devops-final-nginx-1\"}), 1) or on() vector(0)",
          "legendFormat": "nginx",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "clamp_max(count(container_start_time_seconds{name=\"devops-final-prometheus-1\"}), 1) or on() vector(0)",
          "legendFormat": "prometheus",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "Down", "color": "red", "index": 0 },
                "1": { "text": "Up", "color": "green", "index": 1 }
              }
            }
          ]
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 4,
      "title": "Network I/O – Received",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{image!=''}[1m])",
          "legendFormat": "{{ name }}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "id": 5,
      "title": "Network I/O – Transmitted",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "rate(container_network_transmit_bytes_total{image!=''}[1m])",
          "legendFormat": "{{ name }}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    }
  ]
}
